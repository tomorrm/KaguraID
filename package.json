    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@eslint/js": "10.0.1",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "javascript-obfuscator": "5.4.2",
    "prettier": "3.8.3",
    "terser": "5.47.1"
